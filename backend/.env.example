# SQLite database path (relative to backend/ when app is run)
DATABASE_URL=sqlite:///./app/data/reviews.db

# Comma-separated list of origins allowed to call the API
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Public Power BI "publish to web" embed URL (see README for how to get this)
POWERBI_EMBED_URL=https://app.powerbi.com/groups/me/dashboards/64446afb-0fd4-4f14-8b24-969e3ba4efd2?experience=power-bi

# --- Auth (JWT) ---
# Generate a strong secret for production, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
